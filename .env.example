# Groq API anahtarınızı buraya yapıştırın
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Web scraper ayarlari
# Varsayilan true: yalnizca izin verilen Selcuk domainleri islenir
WEB_SCRAPER_ENABLE_DOMAIN_WHITELIST=true

# Whitelist aciksa birden fazla domain icin virgulle ayirin
WEB_SCRAPER_ALLOWED_DOMAINS=selcuk.edu.tr,webadmin.selcuk.edu.tr

# Kurumsal SSL problemi yasiyorsaniz gecici olarak false yapabilirsiniz
WEB_SCRAPER_VERIFY_SSL=true

# SSL dogrulama hatasinda otomatik verify=false fallback denensin mi?
WEB_SCRAPER_ALLOW_INSECURE_FALLBACK=true

WEB_SCRAPER_TIMEOUT_SEC=10
WEB_SCRAPER_MAX_RETRIES=3
WEB_SCRAPER_BACKOFF_SEC=1.0
WEB_SCRAPER_MIN_CONTENT_CHARS=300

# Kurumsal/proje izniyle normalde pasif tutulan manifest kaynaklarini dahil eder.
# Varsayilan kapali kalmalidir.
AUTHORIZED_SOURCE_MODE=false

# Sadece yazili/kurumsal izin varsa true yapin. true iken robots engeli loglanarak yetkili modda gecilir.
WEB_SCRAPER_AUTHORIZED_ROBOTS_OVERRIDE=false

# ─── Crawler Ayarları ───
CRAWL_SEED_URL=https://www.selcuk.edu.tr
CRAWL_MAX_DEPTH=2
CRAWL_DELAY=1.0
CRAWL_MAX_PAGES=500
CRAWL_REQUEST_TIMEOUT=15

# Virgülle ayrılmış hariç tutma desenleri (URL'de geçen pattern'lar)
CRAWL_EXCLUDE_PATTERNS=/login,/signin,/en/,/admin/,/api/,/webmail,/ubs/,/obs/,perbis.selcuk.edu.tr,guvenlik.selcuk.edu.tr,kutuphaneotomasyon.selcuk.edu.tr,bordro.selcuk.edu.tr,odeme.selcuk.edu.tr,obis.selcuk.edu.tr

# Crawler kuyruğunda öne alınacak mevzuat/doküman desenleri
CRAWL_PRIORITY_PATTERNS=yonetmelik,yönetmelik,yonerge,yönerge,mevzuat,dokuman,doküman,belge,staj,burs,cift,çift,diploma,mazeret

# User-Agent rotation (virgülle ayrılmış, boş bırakılırsa varsayılanlar kullanılır)
CRAWL_USER_AGENTS=

# ==== FLASH CHANNEL (Öncelikli Sayfalar) ====
PRIORITY_URLS=https://www.selcuk.edu.tr/Duyurular,https://www.selcuk.edu.tr/Haberler

# ==== ADMIN DASHBOARD ====
# Bos birakilirsa admin paneli devre disi kalir.
ADMIN_PASSWORD=
